{
    "name": "mathiasgrimm/glimpse-cli",
    "description": "Convert, optimize, resize, thumbnail and inspect images from your terminal. The first-party CLI for glimpseimg.com, the image API for developers.",
    "keywords": ["glimpse", "image", "cli", "convert", "optimize", "resize", "thumbnail", "jpg", "jpeg", "gif", "png", "webp", "avif"],
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/mathiasgrimm/glimpse-cli/issues",
        "source": "https://github.com/mathiasgrimm/glimpse-cli"
    },
    "authors": [
        {
            "name": "Mathias Grimm",
            "email": "mathiasgrimm@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "mathiasgrimm/glimpse-php": "^1.0",
        "illuminate/http": "^12.17",
        "laravel-zero/framework": "^12.0.2",
        "laravel-zero/phar-updater": "^1.4",
        "symfony/finder": "^7.2"
    },
    "require-dev": {
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2",
        "phpstan/phpstan": "^2.2"
    },
    "suggest": {
        "ext-imagick": "Far tighter size estimates, plus AVIF and CMYK support, for the analyze command",
        "ext-gd": "Far tighter size estimates for the analyze command when Imagick is unavailable"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "lint": "pint --parallel",
        "lint:check": "pint --parallel --test",
        "types:check": "phpstan analyse",
        "test": [
            "@lint:check",
            "@types:check",
            "@php vendor/bin/pest"
        ],
        "ci:check": [
            "@test"
        ]
    },
    "config": {
        "platform": {
            "php": "8.2.0"
        },
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/glimpse"]
}
